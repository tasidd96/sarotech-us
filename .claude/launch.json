{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "PATH=/opt/homebrew/bin:$PATH exec npm run dev"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "next-prod",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "PATH=/opt/homebrew/bin:$PATH exec npm run start -- -p 3002"],
      "port": 3002,
      "autoPort": true
    }
  ]
}
