# HighLevel (GoHighLevel) API v2 — server-side inventory/products.
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
#
# For a single-location integration, the simplest option is a Private
# Integration Token (PIT) generated from the sub-account settings.
# Docs: https://marketplace.gohighlevel.com/docs/

# Sub-account (location) ID. Find it in the GHL URL or under Settings → Business Profile.
HIGHLEVEL_LOCATION_ID=

# Private Integration Token — must include scopes:
#   products.readonly
#   products/prices.readonly
HIGHLEVEL_ACCESS_TOKEN=

# Pinned API version header. Leave as-is unless you need a newer version.
HIGHLEVEL_API_VERSION=2021-07-28

# ─────────────────────────────────────────────────────────────
# Google Analytics 4 — measurement ID (format: G-XXXXXXXXXX).
# When set, GoogleAnalytics component injects the gtag.js tag.
# Leave blank to disable. Must be set on Vercel as Production + Preview.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─────────────────────────────────────────────────────────────
# Vercel Blob — base URL for CDN-hosted assets (PDFs, technical drawings,
# project photos). The `asset()` helper in src/lib/asset.ts prepends this
# to paths like /installation_guides/... so the site loads them from the
# CDN in production and falls back to /public/ in local dev if unset.
#
# Populate via: npx vercel env pull .env.local  (once the Blob store is
# connected to the Vercel project). Format:
#   https://<store-id>.public.blob.vercel-storage.com
NEXT_PUBLIC_ASSET_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Vercel Blob — write token for the one-shot upload script at
# scripts/upload-assets.mjs. Not needed at runtime. Auto-populated by
# `vercel env pull` when the Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=
